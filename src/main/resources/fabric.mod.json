{
  "schemaVersion": 1,
  "id": "capyclient",
  "version": "${version}",
  "name": "Capy Client",
  "description": "Capy Client adds many quality of life features to Minecraft.",
  "authors": [
    "Bewis09", "Minkxxy"
  ],
  "contact": {
    "homepage": "https://modrinth.com/mod/capyclient/",
    "sources": "https://github.com/capyclient-team/capyclient-v3"
  },
  "license": "Capy Client Licence 1.0",
  "icon": "assets/capyclient/icon.png",
  "environment": "*",
  "entrypoints": {
    "client": [
      {
        "value": "net.bewis09.capyclient.BewisclientInitializer",
        "adapter": "kotlin"
      }
    ],
    "main": [
      {
        "value": "net.bewis09.capyclient.server.BewisclientServer",
        "adapter": "kotlin"
      }
    ],
    "fabric-datagen": [
      {
        "value": "net.bewis09.capyclient.util.BewisclientDataGenerator",
        "adapter": "kotlin"
      }
    ],
    "capyclient": [
      {
        "value": "net.bewis09.capyclient.api.impl.BewisclientSelfAPIEntrypoint",
        "adapter": "kotlin"
      }
    ]
  },
  "mixins": [
    {
      "config": "capyclient.client.mixins.json",
      "environment": "client"
    },
    {
      "config": "capyclient.independent.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=0.18.4",
    "minecraft": "${version_range}",
    "java": ">=21",
    "fabric-api": "*",
    "fabric-language-kotlin": "*"
  }
}